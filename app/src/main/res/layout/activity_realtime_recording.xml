<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFBFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp">

            <!-- 返回按钮 -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#374151" />

            <!-- 设备名 -->
            <TextView
                android:id="@+id/tvDeviceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="音立方"
                android:textColor="#111827"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 电量胶囊 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_status_pill"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_lock_idle_charging"
                    android:tint="#2563EB" />

                <TextView
                    android:id="@+id/tvBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="--"
                    android:textColor="#2563EB"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 存储胶囊 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_status_pill"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:tint="#2563EB" />

                <TextView
                    android:id="@+id/tvStorage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="--"
                    android:textColor="#2563EB"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 中央录音区域 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <!-- 声波环 -->
                <com.example.myapplication.ble.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_width="240dp"
                    android:layout_height="240dp" />

                <!-- 计时器 -->
                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:text="00:00"
                    android:textColor="#111827"
                    android:textSize="40sp"
                    android:textStyle="bold" />

                <!-- 状态文字 -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="点击下方按钮开始录音"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- 底部操作区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp">

            <!-- 文件路径（停止后显示） -->
            <LinearLayout
                android:id="@+id/pathContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_device_list_container"
                android:orientation="vertical"
                android:padding="14dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已保存"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFilePath"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="middle"
                    android:maxLines="2"
                    android:text=""
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 录音按钮 -->
            <FrameLayout
                android:id="@+id/btnRecord"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true">

                <!-- 外圈 -->
                <View
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_record_outer_ring" />

                <!-- 内圆（录音状态变色） -->
                <View
                    android:id="@+id/recordDot"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_record_dot_idle" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
